# 외부 Spring API 베이스 URL
# NEXT_PUBLIC_* 는 클라이언트 번들에 노출됨 → 비밀값 절대 금지 (conventions #7)
NEXT_PUBLIC_API_BASE_URL=

# 카카오톡 공유(Kakao JS SDK) — JavaScript 키
# publishable(도메인 제한) 키라 NEXT_PUBLIC 노출 OK. 실제 값은 .env.local 에만.
# Kakao Developers > 내 애플리케이션 > 앱 키 > JavaScript 키
# 미설정 시 카카오 공유는 링크 복사 fallback (src/lib/share.ts)
NEXT_PUBLIC_KAKAO_JS_KEY=

# Mixpanel 프로젝트 토큰 — 클라이언트 전송 전용 write key라 NEXT_PUBLIC 노출 OK.
# 미설정 시 analytics.ts가 트래킹을 조용히 건너뜀.
NEXT_PUBLIC_MIXPANEL_TOKEN=
